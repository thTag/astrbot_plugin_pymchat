{
    "username": {
        "type": "string",
        "required": true,
        "description": "PymChat 登录用户名"
    },
    "password": {
        "type": "string",
        "required": true,
        "description": "PymChat 登录密码",
        "obvious_hint": true
    },
    "bot_name": {
        "type": "string",
        "default": "bot",
        "description": "机器人昵称，用于消息中的 @ 检测"
    },
    "trigger_keyword": {
        "type": "string",
        "default": "th",
        "description": "触发 AI 回复的关键词"
    },
    "api_base": {
        "type": "string",
        "default": "https://chat.qplm.xyz/api/ac.php",
        "description": "PymChat API 地址"
    },
    "poll_interval": {
        "type": "int",
        "default": 3,
        "description": "消息轮询间隔（秒）"
    },
    "browser_id": {
        "type": "string",
        "default": "astrbot_pymchat",
        "description": "浏览器标识"
    }
}